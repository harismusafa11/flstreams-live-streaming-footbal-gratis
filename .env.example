# Environment Variables untuk FL Streams

# ============================================
# SUPABASE (Required untuk Live Chat)
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# ============================================
# ADSTERRA ADVERTISING KEYS (Optional)
# Dapatkan hash key dari dashboard Adsterra untuk masing-masing ukuran iklan:
# ============================================
NEXT_PUBLIC_ADSTERRA_KEY_728X90=""   # Untuk banner atas (desktop)
NEXT_PUBLIC_ADSTERRA_KEY_320X50=""   # Untuk banner atas (mobile)
NEXT_PUBLIC_ADSTERRA_KEY_300X250=""  # Untuk banner sidebar / bawah chat (desktop/mobile)
